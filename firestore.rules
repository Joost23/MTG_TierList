rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Decks — any authenticated user can read; write if logged in
    match /decks/{deckId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Player avatars (keyed by display name, not UID)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Auth profiles (keyed by UID)
    match /userProfiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Pod chat
    match /messages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // Game sessions — pod tracker + playtester
    match /gameSessions/{sessionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;

      // Private card zones (hand + library) — only the owning player
      match /privateZones/{uid} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
